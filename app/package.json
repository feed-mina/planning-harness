{
  "name": "harness-meeting-app",
  "version": "0.1.0",
  "private": true,
  "description": "기획 하네스 회의록 메이커 — Cloudflare Worker 멀티페이지 앱 (Epic #3)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply harness-meeting-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply harness-meeting-db --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
