# planning-harness 동기화 대상 설정.
# 이 파일만 바꾸면 다른 프로젝트에서도 그대로 동작한다 (공통 모듈화의 핵심).
#
# 보드 위치: https://github.com/users/<OWNER>/projects/<PROJECT_NUMBER>
#         또는 https://github.com/orgs/<OWNER>/projects/<PROJECT_NUMBER>

# 값에 공백이 있으면 반드시 따옴표로 감싼다 (bash `source` 호환).
OWNER="feed-mina"                       # 사용자 또는 org 로그인
PROJECT_NUMBER="1"                      # Project V2 번호
REPO="feed-mina/planning-harness"       # 이슈를 생성할 repo (owner/name)
PROJECT_TITLE="기획 루프"               # 보고용 표시 이름

# 새 이슈에 기본으로 붙일 라벨 (쉼표 구분)
DEFAULT_LABELS="from-meeting,todo"
